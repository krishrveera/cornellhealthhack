# Environment Variables Template
# Copy this file to .env and fill in your values

# ── LLM Provider Configuration ──
# Choose which LLM to use: "openai", "gemini", or "anthropic" (default: gemini)
LLM_PROVIDER=openai

# OpenAI API Key (for GPT - RECOMMENDED)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (alternative LLM provider - OPTIONAL)
# Get your free API key at: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API Key (alternative LLM provider - OPTIONAL)
# Only needed if you want to use Claude instead of OpenAI/Gemini
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Flask Configuration ──
# Flask Environment (development, production, testing)
FLASK_ENV=development

# Secret Key (generate a random string for production)
SECRET_KEY=change-this-to-a-random-secret-key-in-production
